{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://database.locobox.ch/schemas/taxonomy-item.schema.json",
  "title": "Locobox Taxonomy Item",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "name", "slug"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "description": {
      "type": "string"
    }
  }
}
