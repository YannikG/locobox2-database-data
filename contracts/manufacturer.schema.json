{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://database.locobox.ch/schemas/manufacturer.schema.json",
  "title": "Locobox Manufacturer Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "name", "slug"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "logoUrl": {
      "type": "string",
      "format": "uri"
    },
    "website": {
      "type": "string",
      "format": "uri"
    },
    "wikipedia": {
      "type": "string",
      "format": "uri"
    },
    "description": {
      "type": "string"
    },
    "country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    }
  }
}
