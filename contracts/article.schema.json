{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://database.locobox.ch/schemas/article.schema.json",
  "title": "Locobox Community Article",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "manufacturer",
    "articleNumber",
    "releaseDate",
    "uvp",
    "model"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "manufacturer": {
      "type": "string",
      "minLength": 1
    },
    "articleNumber": {
      "type": "string",
      "minLength": 1
    },
    "setNumber": {
      "type": ["string", "null"]
    },
    "releaseDate": {
      "description": "Kalenderjahr (YYYY), volles Datum (YYYY-MM-DD) oder null, wenn noch nicht gesetzt.",
      "oneOf": [
        { "type": "null" },
        {
          "type": "string",
          "pattern": "^\\d{4}(-\\d{2}-\\d{2})?$"
        }
      ]
    },
    "uvp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["amount", "currency"],
      "properties": {
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "country",
        "operator",
        "type",
        "number",
        "livery",
        "scale",
        "electricSystem",
        "era"
      ],
      "properties": {
        "country": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^[A-Z]{2}$" }
          ]
        },
        "operator": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "type": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "number": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "livery": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "scale": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "electricSystem": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "era": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "decoderInterface": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "variantGroup": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "couplerSystem": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "luepMm": {
          "oneOf": [
            { "type": "null" },
            { "type": "number", "minimum": 0 }
          ]
        },
        "minRadiusMm": {
          "oneOf": [
            { "type": "null" },
            { "type": "number", "minimum": 0 }
          ]
        },
        "features": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "description": {
      "type": "string"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "identifiers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ean": {
          "type": "string",
          "pattern": "^([0-9]{8}|[0-9]{13}|[0-9]{14})$"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "Hauptproduktbild"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
